; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Vial Story"
run/main_scene="res://scenes/MainMenu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

Settings="*res://scripts/autoload/settings.gd"
Clock="*res://scripts/autoload/clock.gd"
Rng="*res://scripts/autoload/rng.gd"
PlayerProfile="*res://scripts/autoload/player_profile.gd"
Inventory="*res://scripts/autoload/inventory.gd"
ContentRegistry="*res://scripts/autoload/content_registry.gd"
Resolve="*res://scripts/autoload/resolve.gd"
Skills="*res://scripts/autoload/skills.gd"
Brewing="*res://scripts/autoload/brewing.gd"
Alchemy="*res://scripts/autoload/alchemy.gd"
Shop="*res://scripts/autoload/shop.gd"
Herbalism="*res://scripts/autoload/herbalism.gd"
Economy="*res://scripts/autoload/economy.gd"
Academy="*res://scripts/autoload/academy.gd"
Demonology="*res://scripts/autoload/demonology.gd"
Draconology="*res://scripts/autoload/draconology.gd"
LeyLines="*res://scripts/autoload/ley_lines.gd"
Summoning="*res://scripts/autoload/summoning.gd"
Transmutation="*res://scripts/autoload/transmutation.gd"
Story="*res://scripts/autoload/story.gd"
LoveInterests="*res://scripts/autoload/love_interests.gd"
Characters="*res://scripts/autoload/characters.gd"
SceneDirector="*res://scripts/autoload/scene_director.gd"
QuestManager="*res://scripts/autoload/quest_manager.gd"
SaveManager="*res://scripts/autoload/save_manager.gd"
GameFlow="*res://scripts/autoload/game_flow.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[gui]

theme/custom="res://theme/ui_theme.tres"

[importer_defaults]

texture={
"compress/mode": 0,
"mipmaps/generate": false
}

[layer_names]

2d_physics/layer_1="Player"
2d_physics/layer_2="Walls"
2d_physics/layer_3="Enemies"

[physics]

3d/physics_engine="Jolt Physics"
